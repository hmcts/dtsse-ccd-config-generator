{
  "name": "@hmcts/xui-header",
  "version": "0.0.0",
  "description": "Shared SSR-first XUI header package",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "src/nunjucks",
    "src/styles",
    "README.md",
    "SPEC.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "preview": "npm run build && node ./dev/server.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./nunjucks/macro.njk": "./src/nunjucks/macro.njk",
    "./styles/xui-header.css": "./src/styles/xui-header.css"
  },
  "devDependencies": {
    "express": "^5.1.0",
    "nunjucks": "^3.2.4",
    "typescript": "^5.8.2"
  }
}
