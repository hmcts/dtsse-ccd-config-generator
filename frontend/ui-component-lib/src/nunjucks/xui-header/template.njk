<hmcts-xui-header data-module="hmcts-xui-header">
  <template shadowrootmode="open">
    <link rel="stylesheet" href="{{ params.assetsPath }}/xui-header-shadow.css">
    <header class="xui-header xui-header--{{ params.theme.key or 'default' }}">
      <div class="xui-header__surface">
        <a href="{{ params.skipLink.href }}" class="govuk-skip-link">
          {{ params.skipLink.text }}
        </a>

        <div class="hmcts-header">
          <div class="hmcts-header__container">
            {% if params.theme.logo == "judicial" %}
              <div class="judicial-header__logo">
                <img
                  class="img-responsive"
                  alt=""
                  src="{{ params.assetsPath }}/images/govuk-crest-jcm.png"
                  width="83">
              </div>
              <div class="govuk-header__logo"></div>
              <a class="hmcts-header__link" href="{{ params.title.href }}">
                {{ params.title.text }}
              </a>
            {% elif params.theme.logo == "myhmcts" %}
              <div class="govuk-header__logo">
                <a href="{{ params.title.href }}" class="govuk-header__link govuk-header__link--homepage">
                  <span class="govuk-header__logotype">
                    <span class="govuk-header__logotype-text">MyHMCTS</span>
                  </span>
                </a>
              </div>
              <a class="hmcts-header__link" href="{{ params.title.href }}">
                {{ params.title.text }}
              </a>
            {% else %}
              <div class="hmcts-header__logo">
                <a class="hmcts-header__link" href="{{ params.title.href }}">
                  {{ params.title.text }}
                </a>
              </div>
            {% endif %}

            {% if params.accountNav.items.length %}
              <div class="hmcts-header__content">
                <nav class="hmcts-header__navigation" aria-label="{{ params.accountNav.label }}">
                  <ul class="hmcts-header__navigation-list">
                    {% for item in params.accountNav.items %}
                      <li class="hmcts-header__navigation-item">
                        <a class="hmcts-header__navigation-link" href="{{ item.href }}">
                          {{ item.text }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                </nav>
              </div>
            {% endif %}
          </div>
        </div>

        {% if params.primaryNav.leftItems.length or params.primaryNav.rightItems.length %}
          <div class="hmcts-primary-navigation transparent-background">
            <div class="hmcts-primary-navigation__container">
              {% if params.theme.logo != "none" %}
                <div class="govuk-header__logo"></div>
              {% endif %}

              <nav class="hmcts-primary-navigation__nav" aria-label="Primary navigation">
                <ul class="hmcts-primary-navigation__list">
                  {% for item in params.primaryNav.leftItems %}
                    <li class="hmcts-primary-navigation__item">
                      <a class="hmcts-primary-navigation__link" href="{{ item.href }}">
                        {{ item.text }}
                      </a>
                    </li>
                  {% endfor %}
                </ul>

                {% if params.primaryNav.rightItems.length %}
                  <ul class="hmcts-primary-navigation__list hmcts-primary-navigation__list--right">
                    {% for item in params.primaryNav.rightItems %}
                      <li class="hmcts-primary-navigation__item">
                        <a class="hmcts-primary-navigation__link" href="{{ item.href }}">
                          {{ item.text }}
                        </a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}
              </nav>
            </div>
          </div>
        {% endif %}
      </div>
    </header>
  </template>
</hmcts-xui-header>
