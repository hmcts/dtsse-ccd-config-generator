{
  "name": "@hmcts-cft/cft-ui-component-lib",
  "version": "0.1.0-alpha.3",
  "description": "Shared SSR-first HMCTS CFT UI component library",
  "private": false,
  "type": "module",
  "main": "./dist/cjs/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "src/nunjucks",
    "src/styles",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node ./scripts/prepare-cjs.mjs",
    "test": "npm run build && node --test test/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./policy": {
      "types": "./dist/policy/index.d.ts",
      "import": "./dist/policy/index.js",
      "require": "./dist/cjs/policy/index.js"
    },
    "./footer": {
      "types": "./dist/footer/index.d.ts",
      "import": "./dist/footer/index.js",
      "require": "./dist/cjs/footer/index.js"
    },
    "./nunjucks/xui-header/macro.njk": "./src/nunjucks/xui-header/macro.njk",
    "./nunjucks/footer/macro.njk": "./src/nunjucks/footer/macro.njk",
    "./styles/ui-component-lib.css": "./src/styles/ui-component-lib.css",
    "./styles/xui-header.css": "./src/styles/xui-header-shadow.css"
  },
  "publishConfig": {
    "registry": "https://pkgs.dev.azure.com/hmcts/Artifacts/_packaging/hmcts-lib/npm/registry/"
  },
  "peerDependencies": {
    "nunjucks": ">=3"
  },
  "devDependencies": {
    "nunjucks": "^3.2.4",
    "typescript": "^5.8.2"
  }
}
